class Solution {
    public int getSecondLargest(int[] arr) {
        int largest1 = -1;
        int largest2 = -1;

        for (int i = 0; i < arr.length; i++) {
            if (arr[i] > largest1) {
                largest2 = largest1;
                largest1 = arr[i];
            } 
            else if (arr[i] > largest2 && arr[i] != largest1) {
                largest2 = arr[i];
            }
        }

        return largest2;
    }
}
